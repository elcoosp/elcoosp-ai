{
  "name": "@elcoosp-ai/seedling",
  "version": "0.1.11",
  "description": "AI-powered GitHub issue generator and syncer – turn your implementation plans and specs into trackable issues, automatically.",
  "keywords": [
    "github",
    "issues",
    "ai",
    "automation",
    "project-management"
  ],
  "author": "elcoosp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elcoosp/elcoosp-ai"
  },
  "bugs": {
    "url": "https://github.com/elcoosp/elcoosp-ai/issues"
  },
  "homepage": "https://github.com/elcoosp/elcoosp-ai#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "seedling": "./dist/cjs/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "check": "tsc --noEmit",
    "test": "vitest",
    "test:gen": "pnpm build && node ./dist/cjs/cli.cjs gen --plan ./examples/plan.md --specs ./examples/specs --out ./test-issues",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.116",
    "ai-sdk-ollama": "^3.8.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "slugify": "^1.6.6",
    "zod": "^4.3.6"
  }
}
